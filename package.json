{
  "name": "loyalty-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:ci":          "playwright test --project=fe-ci",
    "test:e2e":         "playwright test --project=fe-e2e",
    "test:all":         "playwright test",
    "test:ci:headed":   "playwright test --project=fe-ci --headed",
    "test:e2e:headed":  "playwright test --project=fe-e2e --headed",
    "test:ci:video":    "cross-env VIDEO=on playwright test --project=fe-ci --headed",
    "test:e2e:video":   "cross-env VIDEO=on playwright test --project=fe-e2e --headed",
    "test:ci:ui":       "playwright test --project=fe-ci --ui",
    "test:e2e:ui":      "playwright test --project=fe-e2e --ui"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@playwright/test": "^1.44.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.2.0"
  }
}
